# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/driver_db"

# Server
PORT=8000
NODE_ENV=development

# Routing provider
# auto = Google Routes if GOOGLE_MAPS_API_KEY exists, otherwise Mapbox if MAPBOX_ACCESS_TOKEN exists, otherwise OSRM fallback
ROUTING_PROVIDER="auto"
GOOGLE_MAPS_API_KEY=""
MAPBOX_ACCESS_TOKEN=""

# Optional: CORS allowlist (comma-separated for multiple origins)
# Example: CORS_ORIGIN="http://localhost:5173,https://your-web.vercel.app"
CORS_ORIGIN="http://localhost:5173"

# Legacy fallback (if CORS_ORIGIN is not set)
FRONTEND_ORIGIN="http://localhost:5173"

# Web client
VITE_API_BASE_URL="http://localhost:8000/api"
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Mobile client
EXPO_PUBLIC_API_BASE_URL="http://localhost:8000/api"
EXPO_PUBLIC_DOMAIN=""
EXPO_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
