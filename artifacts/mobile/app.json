{
  "expo": {
    "name": "بايلوت - تطبيق السائق",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111216"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "يحتاج التطبيق إلى موقعك لمشاركته مع العملاء أثناء التوصيل",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "يحتاج التطبيق إلى موقعك في الخلفية لتتبع رحلاتك بدقة",
        "NSLocationAlwaysUsageDescription": "يحتاج التطبيق إلى موقعك في الخلفية لتتبع رحلاتك بدقة"
      },
      "backgroundModes": ["location", "fetch"]
    },
    "android": {
      "package": "com.drivermaster.mobile",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "يحتاج بايلوت إلى موقعك لمشاركته أثناء التوصيل",
          "locationAlwaysAndWhenInUsePermission": "يحتاج بايلوت إلى موقعك في الخلفية لتتبع رحلاتك",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
